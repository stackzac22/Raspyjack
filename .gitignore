loot/**/*.hash
loot/**/*.john
loot/**/*.potfile
loot/**/*.xml
loot/Responder/
loot/Handshakes/
loot/Credentials/
loot/Screenshots/

# --- stored wifi credentials ---
wifi/configs/
*.wpa_supplicant.conf

# --- frame mirrors / runtime scratch ---
*.frame
